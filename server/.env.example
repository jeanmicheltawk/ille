# Required — PostgreSQL connection string
DATABASE_URL=postgresql://ille:ille@localhost:5432/ille
NODE_ENV=development

PORT=3000
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=admin@ille.co
ADMIN_PASSWORD=illeadmin

# Email / newsletter (optional — subscribers are stored even without SMTP)
SITE_URL=https://ille.co
NEWSLETTER_FROM=newsletter@ille.co
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
